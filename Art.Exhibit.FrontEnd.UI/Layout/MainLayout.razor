@inherits LayoutComponentBase
@using Art.Exhibit.FrontEnd.Application.Interfaces.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.FluentUI.AspNetCore.Components
@inject IAuthService AuthService

<div class="page-shell">
    <nav class="navbar">
        <div class="container">
            <a class="nav-brand" href="/">Art Exhibit</a>

            <ul class="nav-links">
                <li><a href="/" class="@IsActive("/")">Accueil</a></li>
                <li><a href="/dashboard" class="@IsActive("/dashboard")">Tableau de bord</a></li>
                <li><a href="/submit" class="@IsActive("/submit")">Soumettre une oeuvre</a></li>
            </ul>

            <div class="nav-actions">
                <AuthorizeView>
                    <Authorized>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="LogoutAsync">Sign out</FluentButton>
                    </Authorized>
                    <NotAuthorized>
                        <FluentAnchor Href="/login" Appearance="Appearance.Stealth">Connexion</FluentAnchor>
                        <FluentAnchor Href="/register" Appearance="Appearance.Accent">Inscription</FluentAnchor>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </nav>

    <main class="page-content">
        <div class="container">
            @Body
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <span style="font-family:var(--font-display);">Art Exhibit</span>
            <span>&copy; 2026 Art Exhibit — Projet d'analyse et conception'</span>
        </div>
    </footer>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private string IsActive(string href)
    {
        var current = Nav.ToBaseRelativePath(Nav.Uri);
        var target = href.TrimStart('/');
        return current == target ? "active" : string.Empty;
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/");
    }
}